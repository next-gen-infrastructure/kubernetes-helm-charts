{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "properties": {
    "cronjobs": {
      "description": "Kubernetes Cron Jobs",
      "properties": {
        "affinity": {
          "additionalProperties": false,
          "description": "#\n# Ref: https://kubernetes.io/docs/concepts/configuration/assign-pod-node/#affinity-and-anti-affinity\n# Note: podAffinityPreset, podAntiAffinityPreset, and  nodeAffinityPreset will be ignored when it's set\n#",
          "required": [],
          "title": "affinity",
          "type": "object"
        },
        "cronjobs": {
          "additionalProperties": false,
          "description": "#\n#\n#\n# Example:\n# cronjobs:\n#   test:\n#     concurrencyPolicy: Forbid\n#     suspend: false\n#     schedule: \"0 * * * *\"\n#     command: [\"php\"]\n#     args: [\"bin/console\", \"exec:something\"]\n#     startingDeadlineSeconds: 20\n#     failedJobsHistoryLimit: 10\n#     successfulJobsHistoryLimit: 2\n#     backoffLimit: 6 # number of times it will retries before it is considered failed. The default is 6.\n#     annotations:\n#     resources:\n#       limits:\n#         cpu: 100m\n#         memory: 256Mi\n#       requests:\n#         cpu: 100m\n#         memory: 256Mi\n#     env:\n#       values:\n#         FOO: \"Bar\"\n#       vaultSecret:\n#         API_KEY_A:\n#           path: mySecret\n#           secret: password\n#",
          "required": [],
          "title": "cronjobs",
          "type": "object"
        },
        "env": {
          "additionalProperties": false,
          "description": "#\n#",
          "properties": {
            "configmap": {
              "additionalProperties": false,
              "description": "#\n# E.g.\n# configmap:\n#   API_CONFIG:\n#     name: myConfigMap\n#     key: foo.txt\n#",
              "required": [],
              "title": "configmap",
              "type": "object"
            },
            "refs": {
              "additionalProperties": false,
              "description": "#\n# E.g.\n# refs:\n#   FOO: metadata.name\n#",
              "required": [],
              "title": "refs",
              "type": "object"
            },
            "secret": {
              "additionalProperties": false,
              "description": "#\n# E.g.\n# secret:\n#   API_PASSWORD:\n#     name: mySecret\n#     secret: password\n#",
              "required": [],
              "title": "secret",
              "type": "object"
            },
            "values": {
              "additionalProperties": false,
              "description": "#\n# Supporting helm templates\n# E.g.\n# values:\n#   FOO: \"bar-{{ .Values.global.environment }}\"\n#",
              "required": [],
              "title": "values",
              "type": "object"
            },
            "vaultSecret": {
              "additionalProperties": false,
              "description": "#\n# path - Path within vault to the secret containing environment variable. It will be found in /kv/\u003corg\u003e/\u003cproject\u003e/\u003cenv\u003e/\u003crelease.namespace\u003e\n# secret - Optional name of the variable inside secret. Defaults to the secret key\n# E.g.\n# vaultSecret:\n#  API_KEY:\n#    path: mySecret\n#    secret: password\n#",
              "required": [],
              "title": "vaultSecret",
              "type": "object"
            }
          },
          "required": [],
          "title": "env",
          "type": "object"
        },
        "exampleValue": {
          "default": "common-chart",
          "description": "yaml-language-server: $schema=values.schema.json\n# charts/common\n# It is required by CI/CD tools and processes.\n#\n#",
          "title": "exampleValue",
          "type": "string"
        },
        "fullnameOverride": {
          "default": "",
          "description": "#\n# This overrides that and uses the given string instead.\n#",
          "title": "fullnameOverride",
          "type": "string"
        },
        "global": {
          "additionalProperties": false,
          "description": "#\n# Global Docker image parameters",
          "properties": {
            "environment": {
              "default": "dev",
              "description": "#\n# E.g. feature, stage, dev-2.\n#",
              "title": "environment",
              "type": "string"
            },
            "image": {
              "additionalProperties": false,
              "description": "# Configuration of the image for the deployment\n#",
              "properties": {
                "name": {
                  "default": "",
                  "description": "#\n# E.g.\n# name: \"1234567890.dkr.ecr.eu-central-1.amazonaws.com/example\"\n#",
                  "title": "name",
                  "type": "string"
                },
                "pullPolicy": {
                  "default": "IfNotPresent",
                  "description": "#\n# the kubelet to skip pulling an image if it already exists.\n# Ref: https://kubernetes.io/docs/concepts/containers/images/#updating-images\n#",
                  "title": "pullPolicy",
                  "type": "string"
                },
                "tag": {
                  "default": "latest",
                  "description": "#\n#",
                  "title": "tag",
                  "type": "string"
                }
              },
              "required": [],
              "title": "image",
              "type": "object"
            },
            "org": {
              "default": "",
              "description": "#\n#",
              "title": "org",
              "type": "string"
            },
            "project": {
              "default": "",
              "description": "#\n#",
              "title": "project",
              "type": "string"
            },
            "serviceName": {
              "default": "",
              "description": "#\n# E.g. php-admin, service-api\n#",
              "title": "serviceName",
              "type": "string"
            }
          },
          "required": [],
          "title": "global",
          "type": "object"
        },
        "hostPid": {
          "default": false,
          "description": "#\n# E.g.\n# hostPid: true",
          "title": "hostPid",
          "type": "boolean"
        },
        "nameOverride": {
          "default": "",
          "description": "#\n#\n# This overrides that and uses the given string instead.\n#",
          "title": "nameOverride",
          "type": "string"
        },
        "nodeAffinityPreset": {
          "additionalProperties": false,
          "description": "#\n# Ref: https://kubernetes.io/docs/concepts/scheduling-eviction/assign-pod-node/#node-affinity\n#",
          "properties": {
            "key": {
              "default": "",
              "description": "#\n# E.g.\n# key: \"topology.kubernetes.io/zone\"\n#",
              "title": "key",
              "type": "string"
            },
            "type": {
              "default": "",
              "description": "#\n#",
              "title": "type",
              "type": "string"
            },
            "values": {
              "description": "#\n# E.g.\n# values:\n#   - eu-central-1a\n#   - eu-central-1b\n#   - eu-central-1c\n#",
              "items": {
                "required": []
              },
              "title": "values",
              "type": "array"
            }
          },
          "required": [],
          "title": "nodeAffinityPreset",
          "type": "object"
        },
        "nodeSelector": {
          "additionalProperties": false,
          "description": "#\n# Ref: https://kubernetes.io/docs/user-guide/node-selection/\n#",
          "required": [],
          "title": "nodeSelector",
          "type": "object"
        },
        "podAffinityPreset": {
          "default": "",
          "description": "#\n# ref: https://kubernetes.io/docs/concepts/scheduling-eviction/assign-pod-node/#inter-pod-affinity-and-anti-affinity\n#",
          "title": "podAffinityPreset",
          "type": "string"
        },
        "podAntiAffinityPreset": {
          "default": "soft",
          "description": "#\n# Ref: https://kubernetes.io/docs/concepts/scheduling-eviction/assign-pod-node/#inter-pod-affinity-and-anti-affinity\n# Allowed values: soft, hard\n#",
          "title": "podAntiAffinityPreset",
          "type": "string"
        },
        "podSecurityContext": {
          "additionalProperties": false,
          "description": "#\n# Ref: https://kubernetes.io/docs/tasks/configure-pod-container/security-context/#set-the-security-context-for-a-pod\n# E.g.\n# podSecurityContext:\n#   runAsUser: 1000\n#   runAsGroup: 65534\n#   runAsNonRoot: true\n#   fsGroup: 1000\n#",
          "required": [],
          "title": "podSecurityContext",
          "type": "object"
        },
        "resources": {
          "additionalProperties": false,
          "description": "#\n# ref: https://kubernetes.io/docs/user-guide/compute-resources/",
          "properties": {
            "limits": {
              "additionalProperties": false,
              "description": "#\n# E.g.\n# limits:\n#   cpu: 50m\n#   memory: 50Mi\n#",
              "required": [],
              "title": "limits",
              "type": "object"
            },
            "requests": {
              "additionalProperties": false,
              "description": "#\n# E.g.\n# requests:\n#   cpu: 10m\n#   memory: 50Mi\n#",
              "required": [],
              "title": "requests",
              "type": "object"
            }
          },
          "required": [],
          "title": "resources",
          "type": "object"
        },
        "securityContext": {
          "additionalProperties": false,
          "description": "#\n# Ref: https://kubernetes.io/docs/tasks/configure-pod-container/security-context/\n# E.g.\n# securityContext:\n#   allowPrivilegeEscalation: false\n#   readOnlyRootFilesystem: true\n#   capabilities:\n#     drop: [\"ALL\"]\n#",
          "required": [],
          "title": "securityContext",
          "type": "object"
        },
        "serviceAccount": {
          "additionalProperties": false,
          "description": "#\n# Ref: https://kubernetes.io/docs/tasks/configure-pod-container/configure-service-account/",
          "properties": {
            "annotations": {
              "additionalProperties": false,
              "description": "#\n#",
              "required": [],
              "title": "annotations",
              "type": "object"
            },
            "create": {
              "default": false,
              "description": "#\n#",
              "title": "create",
              "type": "boolean"
            },
            "name": {
              "default": "",
              "description": "#\n# If not set and create is true, a name is generated using the fullname template\n#",
              "title": "name",
              "type": "string"
            }
          },
          "required": [],
          "title": "serviceAccount",
          "type": "object"
        },
        "tolerations": {
          "description": "#\n# Ref: https://kubernetes.io/docs/concepts/configuration/taint-and-toleration/\n#",
          "items": {
            "required": []
          },
          "title": "tolerations",
          "type": "array"
        },
        "volumes": {
          "additionalProperties": false,
          "description": "#\n# E.g.\n# volumes:\n#   shared-files:\n#     mountPath: /tmp/shared\n#     emptyDir: true\n#   host-files:\n#     mountPath: /var/lib/logs\n#     hostPath: /var/lib/logs\n#   central-config:\n#     mountPath: /central-config\n#     configMap:\n#       application.yaml: |\n#         configserver:\n#           name:  JHipster Registry\n#           status: Connected to the JHipster Registry running in Kubernetes\n#  credentials:\n#    mountPath: /var/lib/.key\n#    secretName: kubernetes-secret\n#  vaultCredentials:\n#    mountPath: /var/lib\n#    vaultPath: my_secret_files\n#    items:\n#      - key.pass",
          "required": [],
          "title": "volumes",
          "type": "object"
        }
      },
      "required": [],
      "title": "cronjobs",
      "type": "object"
    },
    "global": {
      "additionalProperties": false,
      "description": "yaml-language-server: $schema=values.schema.json",
      "properties": {
        "environmentName": {
          "default": "stage",
          "title": "environmentName",
          "type": "string"
        },
        "image": {
          "additionalProperties": false,
          "properties": {
            "pullPolicy": {
              "default": "IfNotPresent",
              "title": "pullPolicy",
              "type": "string"
            },
            "registry": {
              "default": "1234567890.dkr.ecr.eu-central-1.amazonaws.com",
              "title": "registry",
              "type": "string"
            },
            "repository": {
              "default": "k8s/example-service",
              "title": "repository",
              "type": "string"
            },
            "tag": {
              "default": "dev",
              "title": "tag",
              "type": "string"
            }
          },
          "required": [
            "registry",
            "repository",
            "tag",
            "pullPolicy"
          ],
          "title": "image",
          "type": "object"
        },
        "org": {
          "default": "core",
          "title": "org",
          "type": "string"
        },
        "production": {
          "default": true,
          "title": "production",
          "type": "boolean"
        },
        "project": {
          "default": "test",
          "title": "project",
          "type": "string"
        },
        "serviceName": {
          "default": "test",
          "title": "serviceName",
          "type": "string"
        }
      },
      "required": [
        "org",
        "serviceName",
        "project",
        "production",
        "environmentName",
        "image"
      ],
      "title": "global",
      "type": "object"
    }
  },
  "required": [
    "global",
    "cronjobs"
  ],
  "type": "object"
}